---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PortfolioGallery from '../components/PortfolioGallery.astro';
---

<BaseLayout title="Portfolio | Bahurani Beauty Parlour - Bridal & Party Makeup Gallery">
  <Header />

  <main>
    <!-- Page Header -->
    <section class="py-16 md:py-24 bg-gradient-to-br from-primary-50 to-white">
      <div class="container mx-auto px-4 text-center">
        <h1 class="text-4xl md:text-5xl font-display font-bold text-secondary-900 mb-4">
          Our Portfolio
        </h1>
        <p class="text-lg text-secondary-600 max-w-2xl mx-auto">
          Explore our stunning collection of bridal transformations, party makeup looks, celebrity moments, and award-winning work by Basumati Verma and team.
        </p>
      </div>
    </section>

    <!-- Portfolio Gallery -->
    <PortfolioGallery />

    <!-- CTA Section -->
    <section class="py-16 md:py-24 bg-secondary-900 text-white">
      <div class="container mx-auto px-4 text-center">
        <h2 class="text-3xl md:text-4xl font-display font-bold mb-4">
          Want to See More?
        </h2>
        <p class="text-lg text-secondary-300 mb-8 max-w-2xl mx-auto">
          Follow us on social media for daily updates and behind-the-scenes content.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="btn-primary bg-primary-600 hover:bg-primary-700 text-white">
            Book Your Session
          </a>
          <a href="https://www.instagram.com/bahurani_beauty_parlour_01" target="_blank" rel="noopener noreferrer" class="btn-secondary border-white text-white hover:bg-white hover:text-secondary-900">
            Follow on Instagram
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
