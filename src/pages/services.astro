---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';

const services = [
  {
    id: 'bridal',
    icon: '💒',
    title: 'Bridal Makeup',
    description: 'Complete bridal makeup package with traditional and contemporary looks for your special day. Our expert artists ensure you look radiant and feel confident on your wedding day.',
    price: '₹8,000 - ₹12,000',
    features: [
      'Pre-bridal consultation and skin analysis',
      'One trial session before the wedding',
      'Full day touch-ups included',
      'Premium international products',
      'Traditional and contemporary looks',
      'Family member makeup available'
    ],
    duration: '3-4 hours',
    includes: ['Face', 'Eyes', 'Lips', 'Contouring', 'False Lashes', 'Setting Spray']
  },
  {
    id: 'hd-bridal',
    icon: '✨',
    title: 'HD Bridal Makeup',
    description: 'High-definition airbrush makeup that looks flawless in person and in photographs. Perfect for destination weddings and high-end events.',
    price: '₹15,000 - ₹25,000',
    features: [
      'HD airbrush technique',
      'Long-lasting 12+ hour formula',
      'Photo and video-ready finish',
      'Luxury international brands',
      'Waterproof and transfer-proof',
      'Bridal trial with HD photos'
    ],
    duration: '4-5 hours',
    includes: ['Airbrush Base', 'HD Contouring', 'Waterproof Eyes', 'Lip Stain', 'Body Makeup', 'Touch-up Kit']
  },
  {
    id: 'party',
    icon: '🎉',
    title: 'Party Makeup',
    description: 'Glamorous makeup for parties, receptions, and special occasions. Get ready to turn heads at your next event!',
    price: '₹2,500 - ₹4,000',
    features: [
      'Customized looks for your outfit',
      'Quick 1-2 hour service',
      'Event-appropriate styling',
      'Touch-up kit included',
      'Photo-ready finish',
      'Home service available'
    ],
    duration: '1-2 hours',
    includes: ['Face Base', 'Eye Makeup', 'Lip Color', 'Contouring', 'Setting']
  },
  {
    id: 'engagement',
    icon: '💍',
    title: 'Engagement Makeup',
    description: 'Elegant and romantic makeup for your engagement ceremony. Soft glam looks that complement your traditional attire.',
    price: '₹5,000 - ₹8,000',
    features: [
      'Soft glam and romantic looks',
      'Photography-friendly application',
      'Traditional jewelry coordination',
      'Long-lasting formula',
      'Trial session included',
      'Family packages available'
    ],
    duration: '2-3 hours',
    includes: ['Face', 'Eyes', 'Lips', 'Contouring', 'Highlighting', 'Setting']
  },
  {
    id: 'hair',
    icon: '💇‍♀️',
    title: 'Hair Styling',
    description: 'Professional hair styling for all occasions - from intricate bridal dos to flowing party curls.',
    price: '₹1,500 - ₹5,000',
    features: [
      'Bridal hairstyles (braids, buns, open)',
      'Party curls and waves',
      'Traditional gajra styling',
      'Hair accessories included',
      'Hair treatment add-ons',
      'Extensions available'
    ],
    duration: '1-3 hours',
    includes: ['Wash & Condition', 'Styling', 'Accessories', 'Hairspray', 'Touch-ups']
  },
  {
    id: 'saree',
    icon: '👘',
    title: 'Saree Draping',
    description: 'Expert saree draping in various styles - traditional Nivi, modern fusion, Bengali, Gujarati, and more.',
    price: '₹800 - ₹1,500',
    features: [
      'Multiple draping styles',
      'Secure and comfortable',
      'Perfect pleats every time',
      'Petticoat adjustment',
      'Accessory styling',
      'Quick draping available'
    ],
    duration: '30-45 minutes',
    styles: ['Nivi', 'Bengali', 'Gujarati', 'Maharashtrian', 'Fusion', 'Belt Style']
  },
  {
    id: 'facial',
    icon: '🌸',
    title: 'Facial & Skin Care',
    description: 'Rejuvenating facials and skin care treatments for glowing, healthy skin.',
    price: '₹1,200 - ₹3,500',
    features: [
      'Deep cleansing facial',
      'Skin brightening treatment',
      'Anti-aging facial',
      'Acne treatment facial',
      'Gold facial',
      'Customized skin care'
    ],
    duration: '1-2 hours',
    includes: ['Cleansing', 'Steaming', 'Extraction', 'Massage', 'Mask', 'Moisturizing']
  },
  {
    id: 'mehndi',
    icon: '🎨',
    title: 'Mehndi Application',
    description: 'Beautiful mehndi designs for brides and special occasions using natural, safe henna.',
    price: '₹2,000 - ₹10,000',
    features: [
      'Traditional bridal mehndi',
      'Modern and Arabic designs',
      'Natural henna paste',
      'Long-lasting dark color',
      'Quick-dry formula',
      'Home service available'
    ],
    duration: '2-6 hours',
    includes: ['Design Consultation', 'Application', 'Aftercare Instructions', 'Touch-up Paste']
  },
  {
    id: 'academy',
    icon: '📚',
    title: 'Makeup Training Courses',
    description: 'Professional makeup courses from beginner to advanced levels. Start your career in the beauty industry.',
    price: '₹25,000 - ₹50,000',
    features: [
      'Beginner to Advanced courses',
      'Hands-on practical training',
      'Certificate upon completion',
      'Product knowledge sessions',
      'Business & marketing guidance',
      'Placement assistance'
    ],
    duration: '1-3 months',
    courses: [
      { name: 'Basic Makeup Course', duration: '1 month', price: '₹25,000' },
      { name: 'Advanced Bridal Course', duration: '2 months', price: '₹40,000' },
      { name: 'Professional Master Class', duration: '3 months', price: '₹50,000' }
    ]
  },
];
---

<BaseLayout title="Our Services | Bahurani Beauty Parlour Varanasi">
  <Header />
  
  <main>
    <!-- Page Header -->
    <section class="bg-gradient-to-br from-primary-600 to-primary-800 text-white py-16 md:py-24">
      <div class="container mx-auto px-4 text-center">
        <h1 class="text-4xl md:text-5xl font-display font-bold mb-4">Our Services</h1>
        <p class="text-lg text-primary-100 max-w-2xl mx-auto">
          Professional beauty services tailored to make you look and feel your best
        </p>
      </div>
    </section>

    <!-- Services List -->
    <section class="py-16 md:py-24 bg-white">
      <div class="container mx-auto px-4">
        {services.map((service, index) => (
          <div 
            id={service.id}
            class={`grid md:grid-cols-2 gap-8 md:gap-12 items-center mb-16 md:mb-24 ${index % 2 === 1 ? 'md:flex-row-reverse' : ''}`}
          >
            <!-- Image Placeholder -->
            <div class={`order-2 md:order-${index % 2 === 1 ? '2' : '1'}`}>
              <div class="aspect-square bg-gradient-to-br from-primary-100 to-primary-200 rounded-2xl flex items-center justify-center">
                <span class="text-8xl">{service.icon}</span>
              </div>
            </div>

            <!-- Content -->
            <div class={`order-1 md:order-${index % 2 === 1 ? '1' : '2'}`}>
              <div class="inline-flex items-center gap-2 bg-primary-100 text-primary-700 px-3 py-1 rounded-full text-sm font-medium mb-4">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                {service.duration}
              </div>
              
              <h2 class="text-3xl md:text-4xl font-display font-bold text-secondary-900 mb-4">
                {service.title}
              </h2>
              
              <p class="text-secondary-600 mb-6 text-lg">
                {service.description}
              </p>

              <!-- Features -->
              <ul class="space-y-3 mb-6">
                {service.features.map((feature) => (
                  <li class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span class="text-secondary-700">{feature}</span>
                  </li>
                ))}
              </ul>

              <!-- Price -->
              <div class="flex items-center justify-between bg-primary-50 rounded-xl p-4 mb-6">
                <span class="text-secondary-600">Starting from</span>
                <span class="text-2xl font-display font-bold text-primary-600">{service.price}</span>
              </div>

              <!-- CTA -->
              <a href="/contact" class="btn-primary">
                Book This Service
              </a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Contact Form -->
    <ContactForm 
      title="Book Your Appointment Today"
      subtitle="Fill out the form and we'll contact you within 24 hours to confirm your booking"
    />
  </main>

  <Footer />
</BaseLayout>
