---
interface Props {
  icon: string;
  title: string;
  description: string;
  price?: string;
  features?: string[];
  href?: string;
}

const { icon, title, description, price, features = [], href } = Astro.props;
---

<article class="card group">
  <a href={href || '#'} class="block p-6 h-full">
    <!-- Icon -->
    <div class="w-14 h-14 bg-primary-100 rounded-xl flex items-center justify-center mb-4 group-hover:bg-primary-600 transition-colors duration-300">
      <span class="text-2xl">{icon}</span>
    </div>

    <!-- Title -->
    <h3 class="text-xl font-display font-semibold text-secondary-900 mb-2 group-hover:text-primary-600 transition-colors">
      {title}
    </h3>

    <!-- Description -->
    <p class="text-secondary-600 mb-4 line-clamp-2">
      {description}
    </p>

    <!-- Features -->
    {features.length > 0 && (
      <ul class="space-y-2 mb-4">
        {features.map((feature) => (
          <li class="flex items-center gap-2 text-sm text-secondary-600">
            <svg class="w-4 h-4 text-primary-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            {feature}
          </li>
        ))}
      </ul>
    )}

    <!-- Price -->
    {price && (
      <div class="flex items-center justify-between pt-4 border-t border-secondary-100">
        <span class="text-sm text-secondary-500">Starting from</span>
        <span class="text-lg font-display font-bold text-primary-600">{price}</span>
      </div>
    )}

    <!-- Learn More Link -->
    {href && (
      <div class="mt-4 flex items-center text-primary-600 font-medium group-hover:translate-x-2 transition-transform">
        Learn More
        <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </div>
    )}
  </a>
</article>
