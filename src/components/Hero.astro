---
interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaLink?: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
}

const {
  title = "Enhance Your Natural Beauty",
  subtitle = "Professional bridal makeup, party makeup & expert makeup training in Varanasi",
  ctaText = "Book Appointment",
  ctaLink = "/contact",
  secondaryCtaText = "Our Services",
  secondaryCtaLink = "/services"
} = Astro.props;
---

<section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary-50 via-white to-primary-100"></div>
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-20 left-10 w-72 h-72 bg-primary-300 rounded-full mix-blend-multiply filter blur-xl animate-pulse"></div>
    <div class="absolute bottom-20 right-10 w-72 h-72 bg-primary-400 rounded-full mix-blend-multiply filter blur-xl animate-pulse" style="animation-delay: 1s;"></div>
  </div>

  <!-- Content -->
  <div class="relative container mx-auto px-4 py-20">
    <div class="max-w-4xl mx-auto text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-white px-4 py-2 rounded-full shadow-md mb-6 animate-fade-in">
        <span class="w-2 h-2 bg-primary-600 rounded-full animate-pulse"></span>
        <span class="text-sm font-medium text-secondary-700">✨ Varanasi's Trusted Beauty Studio</span>
      </div>

      <!-- Main Title -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold text-secondary-900 mb-6 leading-tight animate-slide-up">
        {title}
        <span class="block text-gradient mt-2">With Bahurani</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-lg md:text-xl text-secondary-600 mb-8 max-w-2xl mx-auto animate-slide-up" style="animation-delay: 0.2s;">
        {subtitle}
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center animate-slide-up" style="animation-delay: 0.4s;">
        <a href={ctaLink} class="btn-primary text-lg px-8 py-4">
          {ctaText}
          <svg class="w-5 h-5 ml-2 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href={secondaryCtaLink} class="btn-secondary text-lg px-8 py-4">
          {secondaryCtaText}
        </a>
      </div>

      <!-- Trust Indicators -->
      <div class="mt-12 grid grid-cols-3 gap-4 md:gap-8 animate-fade-in" style="animation-delay: 0.6s;">
        <div class="text-center">
          <p class="text-2xl md:text-3xl font-display font-bold text-primary-600">500+</p>
          <p class="text-sm text-secondary-600">Happy Brides</p>
        </div>
        <div class="text-center">
          <p class="text-2xl md:text-3xl font-display font-bold text-primary-600">1000+</p>
          <p class="text-sm text-secondary-600">Makeovers Done</p>
        </div>
        <div class="text-center">
          <p class="text-2xl md:text-3xl font-display font-bold text-primary-600">50+</p>
          <p class="text-sm text-secondary-600">Students Trained</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-secondary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
